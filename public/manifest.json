{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "idle",
    "sidePanel",
    "activeTab",
    "topSites",
    "bookmarks"
  ],
  "optional_permissions": ["history"],
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/browser-hub_logo.png",
      "32": "icons/browser-hub_logo.png",
      "48": "icons/browser-hub_logo.png",
      "128": "icons/browser-hub_logo.png"
    },
    "default_title": "Browser Hub"
  },
  "icons": {
    "16": "icons/browser-hub_logo.png",
    "32": "icons/browser-hub_logo.png",
    "48": "icons/browser-hub_logo.png",
    "128": "icons/browser-hub_logo.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/scroll-capture.ts"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Toggle Browser Hub Side Panel"
    }
  }
}
