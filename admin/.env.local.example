# Supabase — copy this file to .env.local and fill in your project values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SMTP Configuration (Resend) — used for transactional emails
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM_NAME=Browser Hub
SMTP_FROM_EMAIL=info@yourdomain.com
SMTP_SUPPORT_EMAIL=support@yourdomain.com
# Optional: hosted logo URL (displayed in email header); omit to use text fallback
# SMTP_LOGO_URL=https://yourdomain.com/logo.png
